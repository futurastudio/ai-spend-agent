# Waitlist storage (production). Without these, signups append to
# .data/waitlist.tsv (dev fallback).
#
# Table (run once in the Supabase SQL editor or via migration):
#   create table if not exists public.waitlist (
#     id uuid primary key default gen_random_uuid(),
#     email text not null unique,
#     source_ref text not null default 'direct',
#     created_at timestamptz not null default now()
#   );
#   alter table public.waitlist add column if not exists source_ref text not null default 'direct';
#   alter table public.waitlist enable row level security;
#   -- no policies: only the service-role key (server-side) can read/write.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
