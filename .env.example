# Provider admin keys for real spend sync (Task: accuracy QA / `sync-provider`).
#
# Copy this file to .env (gitignored) and fill in your real keys, OR export
# these variables in your shell. NOTE: the CLI does NOT auto-load .env files —
# it reads the live environment. Either `source` the file first:
#
#   set -a; source .env; set +a
#   ai-spend-agent connect openai
#
# or export the variables directly in your shell profile.
#
# The tool only ever receives the *reference* (e.g. env:OPENAI_ADMIN_KEY);
# raw keys are never stored, persisted, or printed.

# platform.openai.com -> Settings -> Organization -> Admin keys (sk-admin-...)
OPENAI_ADMIN_KEY=

# console.anthropic.com -> Settings -> Admin keys (sk-ant-admin...)
ANTHROPIC_ADMIN_KEY=

# Optional — only if you have these subscriptions:
# Cursor: team admin key, Business plan required
CURSOR_ADMIN_KEY=
# GitHub Copilot: billing-admin token
GITHUB_TOKEN=
